# AI Aggregators Configuration Template
# Скопируйте этот файл в .env и заполните ключами

# =============================================================================
# OPENROUTER CONFIGURATION
# =============================================================================
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR-KEY-HERE

# Модель по умолчанию для OpenRouter
# Популярные варианты:
#   - meta-llama/llama-3.1-70b-instruct (быстро, дёшево)
#   - anthropic/claude-3.5-sonnet (качественный анализ текста)
#   - openai/gpt-4-turbo (сложные задачи)
#   - mistralai/mistral-large (технический анализ)
#   - qwen/qwen-2.5-72b-instruct (классификация)
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-70b-instruct

# Лимит запросов в минуту (для rate limiting)
OPENROUTER_RATE_LIMIT=100

# =============================================================================
# DEEPINFRA CONFIGURATION
# =============================================================================
# Получить ключ: https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=YOUR-KEY-HERE

# Модель по умолчанию для DeepInfra
# Популярные варианты:
#   - meta-llama/Meta-Llama-3.1-70B-Instruct
#   - mistralai/Mistral-Large-Instruct-2407
#   - Qwen/Qwen2.5-72B-Instruct
#   - google/gemma-2-27b-it
DEEPINFRA_DEFAULT_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Лимит запросов в минуту
DEEPINFRA_RATE_LIMIT=200

# =============================================================================
# GENERAL AI SETTINGS
# =============================================================================
# Предпочитаемый агрегатор (openrouter или deepinfra)
AI_AGGREGATOR_PREFERRED=openrouter

# Дневной лимит расходов (USD)
AI_DAILY_BUDGET_USD=10

# Таймаут запроса (мс)
AI_REQUEST_TIMEOUT=30000

# Количество попыток при ошибке
AI_MAX_RETRIES=3

# Задержка между попытками (мс)
AI_RETRY_DELAY_MS=2000

# =============================================================================
# TELEGRAM NOTIFICATIONS (опционально)
# =============================================================================
# Отправлять уведомления о расходах AI
AI_SEND_SPEND_NOTIFICATIONS=true

# Порог уведомления (USD в день)
AI_SPEND_NOTIFICATION_THRESHOLD_USD=5

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
# Логировать токены и стоимость
AI_LOG_TOKEN_USAGE=true

# Отправлять метрики в Prometheus
AI_PROMETHEUS_ENABLED=true
